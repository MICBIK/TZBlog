---
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { siteMeta } from '../../data/content'
import { getSiteProfile, getTimeline } from '../../lib/payload'

const aboutProfile = await getSiteProfile()
const timeline = await getTimeline()
---

<SiteLayout title="关于 | TZBlog" description="TZBlog 的身份说明与站点方向。">
  <ThreeColumnLayout>
    <Fragment slot="left">
    <div class="side-panel flow-sm panel">
       <p class="eyebrow">Profile</p>
    <p class="muted text-sm">本站点的身份档案与架构记录。</p>
    </div>
    </Fragment>

    <Fragment slot="main">
      <article class="about-card panel flow-md" style="padding: 2rem; margin-bottom: 2rem;">
        <p class="eyebrow">About</p>
     <h1 style="font-size: 2.5rem">{aboutProfile.name}</h1>
     <p class="meta-line">{aboutProfile.role}</p>
     <p class="section-copy">{aboutProfile.summary}</p>
     <div class="tag-list mt-1">
       {aboutProfile.techStack.frontend.map((tech: string) => (
         <span class="tag" style="background: rgba(255,255,255,0.02)">{tech}</span>
       ))}
       {aboutProfile.techStack.backend.map((tech: string) => (
         <span class="tag" style="background: rgba(255,255,255,0.02)">{tech}</span>
       ))}
      </div>
   </article>

     <div class="page-intro footer-dock" style="padding: 0; border: none;">
       <p class="eyebrow" style="margin-bottom: 1rem">Timeline / 站点演进轨迹</p>
        <div class="timeline-list" style="display: grid; gap: 1rem;">
     {timeline.map((item) => (
       <article class="timeline-item panel flow-sm" style="padding: 1.5rem">
        <p class="eyebrow">{item.date}</p>
        <h3>{item.title}</h3>
       <p class="muted" style="font-size: 0.95em">{item.summary}</p>
      </article>
       ))}
      </div>
      </div>
  </Fragment>

    <Fragment slot="right">
    <div class="side-panel flow-sm panel">
       <p class="eyebrow">Station Status</p>
     <div class="side-list">
          <div>
       <strong>当前阶段</strong>
    <p class="muted text-sm">{siteMeta.currentStatus}</p>
        </div>
     <div>
          <strong>地点</strong>
     <p class="muted text-sm">{siteMeta.location}</p>
       </div>
        </div>
     </div>
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
