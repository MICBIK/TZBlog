---
import ContentCard from '../../components/ContentCard.astro'
import CollectionHeader from '../../components/CollectionHeader.astro'
import HighlightCard from '../../components/HighlightCard.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getDocs } from '../../lib/payload'

const docsCollection = await getDocs()
const featuredDoc = docsCollection[0]
const docTagCounts = new Map<string, number>()
docsCollection.flatMap((d) => d.tags || []).forEach((t) => docTagCounts.set(t, (docTagCounts.get(t) || 0) + 1))
const docTopTags = [...docTagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 5).map(([tag]) => tag)
---
<SiteLayout title="文档 | TZBlog" description="结构化文档与长期维护说明的入口。">
  <ThreeColumnLayout>
    <Fragment slot="left">
      <CollectionHeader eyebrow="Docs" title="文档中枢" description="结构、版本和章节组织的长期知识平面。" count={docsCollection.length} unit="份结构文档" />
    </Fragment>

    <Fragment slot="main">
      <div class="content-stack">
        {docsCollection.length > 0 ? (
          docsCollection.map((doc) => (
            <ContentCard href={`/docs/${doc.slug}`} eyebrow={doc.version} title={doc.title} summary={doc.summary} meta={`${doc.updatedAt} · ${doc.orbit}`} tags={doc.tags} />
          ))
        ) : (
          <div class="empty-state panel">当前还没有已发布文档，或者 Payload API 暂时不可用。</div>
        )}
      </div>
    </Fragment>

    <Fragment slot="right">
      {docTopTags.length > 0 && (
        <div class="side-panel flow-sm panel">
          <p class="eyebrow">Tags</p>
          <div class="tag-list">
            {docTopTags.map((tag) => (
              <a href={`/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>
            ))}
          </div>
          <a href="/tags" class="muted text-sm">查看全部标签 →</a>
        </div>
      )}
      {featuredDoc ? (
        <HighlightCard eyebrow="Current Priority" title={featuredDoc.title} summary={featuredDoc.summary} href={`/docs/${featuredDoc.slug}`} />
      ) : (
        <div class="empty-state panel">暂无优先文档可显示。</div>
      )}
      <div class="side-panel flow-sm panel">
        <p class="eyebrow">Doc Notes</p>
        <p class="muted text-sm">后续接 Payload 后，文档页会继续保留目录感、版本号和相关文档入口。</p>
      </div>
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
