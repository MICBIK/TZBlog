---
import ArticleBody from '../../components/ArticleBody.astro'
import DetailSidebar from '../../components/DetailSidebar.astro'
import TableOfContents from '../../components/TableOfContents.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getDocs } from '../../lib/payload'

export async function getStaticPaths() {
  const docsCollection = await getDocs()
  return docsCollection.map((doc) => ({ params: { slug: doc.slug }, props: { doc } }))
}

const { doc: currentDoc } = Astro.props
---
<SiteLayout title={`${currentDoc.title} | TZBlog`} description={currentDoc.summary}>
  <ThreeColumnLayout>
    <Fragment slot="left">
      <DetailSidebar eyebrow={currentDoc.version} title={currentDoc.title} summary={currentDoc.summary} chips={[currentDoc.updatedAt, currentDoc.orbit]} tags={currentDoc.tags} />
    </Fragment>

    <Fragment slot="main">
      <ArticleBody sections={currentDoc.sections} />
  </Fragment>
    <Fragment slot="right">
     <TableOfContents sections={currentDoc.sections} label="Doc Directory" />
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
