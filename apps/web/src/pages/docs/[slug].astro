---
import ArticleBody from '../../components/ArticleBody.astro'
import DetailSidebar from '../../components/DetailSidebar.astro'
import TableOfContents from '../../components/TableOfContents.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { docsCollection } from '../../data/content'

export function getStaticPaths() {
 return docsCollection.map((doc) => ({ params: { slug: doc.slug }, props: { doc } }))
}

const { doc } = Astro.props
---
<SiteLayout title={`${doc.title} | TZBlog`} description={doc.summary}>
  <ThreeColumnLayout>
    <Fragment slot="left">
      <DetailSidebar eyebrow={doc.version} title={doc.title} summary={doc.summary} chips={[doc.updatedAt, doc.orbit]} tags={doc.tags} />
    </Fragment>

    <Fragment slot="main">
      <ArticleBody sections={doc.sections} />
  </Fragment>
    <Fragment slot="right">
     <TableOfContents sections={doc.sections} label="Doc Directory" />
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
