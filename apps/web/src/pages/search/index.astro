---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getDocs, getNotes, getPosts, getProjects } from '../../lib/payload'

const [posts, projects, docsCollection, notes] = await Promise.all([
  getPosts(),
  getProjects(),
  getDocs(),
  getNotes(),
])

const searchIndex = [
  ...posts.map((item) => ({ type: '文章', title: item.title, summary: item.summary, href: `/posts/${item.slug}`, meta: `${item.publishedAt} · ${item.readTime}` })),
  ...projects.map((item) => ({ type: '项目', title: item.title, summary: item.summary, href: `/projects/${item.slug}`, meta: `${item.stage} · ${item.updatedAt}` })),
  ...docsCollection.map((item) => ({ type: '文档', title: item.title, summary: item.summary, href: `/docs/${item.slug}`, meta: `${item.version} · ${item.updatedAt}` })),
  ...notes.map((item) => ({ type: '笔记', title: item.title, summary: item.summary, href: `/notes/${item.slug}`, meta: `${item.mood} · ${item.publishedAt}` })),
]

const initialResults = searchIndex.slice(0, 6)
---

<SiteLayout title="搜索 | TZBlog" description="搜索作为一级导航存在，帮助用户快速定位内容。">
  <section class="page-intro panel search-shell">
    <div class="search-layout">
      <div class="flow-md">
        <p class="eyebrow">Search</p>
        <h1>Signal Search Relay</h1>
        <p class="section-copy">搜索不是隐藏功能。当前页面先提供演示检索壳层，后续会切换到 Pagefind 实索引。</p>
        <label class="search-label" for="search-input">输入关键词</label>
        <input
          id="search-input"
          class="search-input"
          type="search"
          placeholder="试着搜：布局、Payload、搜索、动效"
          autocomplete="off"
          data-search-input
        />
      </div>
      <aside class="side-panel flow-sm">
        <p class="eyebrow">Suggested Queries</p>
        <div class="tag-list">
          <button type="button" class="button button-ghost" data-suggest="布局">布局</button>
          <button type="button" class="button button-ghost" data-suggest="Payload">Payload</button>
          <button type="button" class="button button-ghost" data-suggest="搜索">搜索</button>
        </div>
      </aside>
    </div>
  </section>

  <template id="search-card-tpl">
    <article class="search-card panel flow-sm">
      <p class="eyebrow" data-field="type"></p>
      <h3><a data-field="href-title"></a></h3>
      <p class="muted" data-field="summary"></p>
      <p class="meta-line" data-field="meta"></p>
    </article>
  </template>

  <section class="page-section">
    <div class="search-results" aria-live="polite" data-search-results>
      {initialResults.length > 0 ? (
        initialResults.map((item) => (
          <article class="search-card panel flow-sm">
            <p class="eyebrow">{item.type}</p>
            <h3><a href={item.href}>{item.title}</a></h3>
            <p class="muted">{item.summary}</p>
            <p class="meta-line">{item.meta}</p>
          </article>
        ))
      ) : (
        <div class="empty-state panel">当前还没有可搜索的已发布内容，或者 Payload API 暂时不可用。</div>
      )}
    </div>
  </section>

  <script is:inline define:vars={{ searchIndex }}>
    const input = document.querySelector('[data-search-input]')
    const resultRoot = document.querySelector('[data-search-results]')
    const suggestButtons = document.querySelectorAll('[data-suggest]')
    const tpl = document.getElementById('search-card-tpl')

    const createCard = (item) => {
      if (!tpl) return null
      const clone = tpl.content.cloneNode(true)
      clone.querySelector('[data-field="type"]').textContent = item.type
      const link = clone.querySelector('[data-field="href-title"]')
      link.href = item.href
      link.textContent = item.title
      clone.querySelector('[data-field="summary"]').textContent = item.summary
      clone.querySelector('[data-field="meta"]').textContent = item.meta
      return clone
    }

    const render = (items) => {
      if (!resultRoot) return
      resultRoot.innerHTML = ''
      if (!items.length) {
        resultRoot.innerHTML = '<div class="empty-state panel">没搜到匹配信号，换个关键词试试。</div>'
        return
      }
      const frag = document.createDocumentFragment()
      items.forEach((item) => {
        const card = createCard(item)
        if (card) frag.appendChild(card)
      })
      resultRoot.appendChild(frag)
    }

    const runSearch = (query) => {
      const normalized = query.trim().toLowerCase()
      if (!normalized) {
        render(searchIndex.slice(0, 6))
        return
      }
      const matches = searchIndex.filter((item) =>
        [item.title, item.summary, item.type, item.meta].some((field) => field.toLowerCase().includes(normalized))
      )
      render(matches)
    }

    input?.addEventListener('input', (event) => {
      runSearch(event.currentTarget.value)
    })

    suggestButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const value = button.getAttribute('data-suggest') || ''
        if (input) input.value = value
        runSearch(value)
      })
    })
  </script>
</SiteLayout>
