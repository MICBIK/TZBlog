---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getPosts, getProjects, getDocs, getNotes } from '../../lib/payload'

const [posts, projects, docs, notes] = await Promise.all([getPosts(), getProjects(), getDocs(), getNotes()])
const tagCounts = new Map<string, number>()
;[...posts, ...projects, ...docs, ...notes]
  .flatMap((item) => item.tags || [])
  .filter((t) => t.trim())
  .forEach((t) => tagCounts.set(t, (tagCounts.get(t) || 0) + 1))
const suggestedQueries = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map(([tag]) => tag)
---

<SiteLayout title="搜索 | TZBlog" description="全文搜索所有文章、项目、文档和笔记。">
  <section class="page-intro panel search-shell">
    <div class="search-layout">
      <div class="flow-md">
        <p class="eyebrow">Search</p>
        <h1>Signal Search Relay</h1>
        <p class="section-copy">全文搜索所有文章、项目、文档和笔记内容。</p>
        <label class="search-label" for="search-input">输入关键词</label>
        <input
          id="search-input"
          class="search-input"
          type="search"
          placeholder="搜索文章正文、项目描述、文档内容…"
          autocomplete="off"
          data-search-input
        />
      </div>
      <aside class="side-panel flow-sm">
        <p class="eyebrow">Suggested Queries</p>
        <div class="tag-list">
          {suggestedQueries.map((word) => (
            <button type="button" class="button button-ghost" data-suggest={word}>{word}</button>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="page-section">
    <div class="search-results" aria-live="polite" data-search-results>
      <div class="empty-state panel">输入关键词开始搜索。</div>
    </div>
  </section>

  <script is:inline>
    var pagefind = null
    var pagefindReady = false
    var pagefindFailed = false

    async function initPagefind() {
      try {
        pagefind = await import('/pagefind/pagefind.js')
        await pagefind.init()
        pagefindReady = true
      } catch (e) {
        pagefindFailed = true
        console.warn('Pagefind index not available (normal in dev mode)', e)
      }
    }

    var input = document.querySelector('[data-search-input]')
    var resultRoot = document.querySelector('[data-search-results]')
    var suggestButtons = document.querySelectorAll('[data-suggest]')

    function renderResults(items) {
      if (!resultRoot) return
      if (!items.length) {
        resultRoot.innerHTML = '<div class="empty-state panel">没搜到匹配信号，换个关键词试试。</div>'
        return
      }
      resultRoot.innerHTML = items.map(function(item) {
        return '<article class="search-card panel flow-sm">' +
          '<h3><a href="' + item.url + '">' + (item.meta && item.meta.title ? item.meta.title : '无标题') + '</a></h3>' +
          '<p class="muted">' + (item.excerpt || '') + '</p>' +
          '</article>'
      }).join('')
    }

    function renderEmpty() {
      if (!resultRoot) return
      resultRoot.innerHTML = '<div class="empty-state panel">输入关键词开始搜索。</div>'
    }

    async function runSearch(query) {
      var normalized = query.trim()
      if (!normalized) { renderEmpty(); return }
      if (pagefindFailed) {
        if (resultRoot) resultRoot.innerHTML = '<div class="empty-state panel">搜索索引不可用，请先执行构建（pnpm build）后使用 pnpm preview 访问。</div>'
        return
      }
      if (!pagefindReady) {
        if (resultRoot) resultRoot.innerHTML = '<div class="empty-state panel">搜索索引加载中，请稍候…</div>'
        // 等待初始化完成后重试
        var waitTimer = setInterval(function() {
          if (pagefindReady || pagefindFailed) {
            clearInterval(waitTimer)
            runSearch(query)
          }
        }, 100)
        return
      }
      try {
        var search = await pagefind.search(normalized)
        var results = await Promise.all(search.results.slice(0, 10).map(function(r) { return r.data() }))
        renderResults(results)
      } catch (e) {
        console.error('Search failed:', e)
        if (resultRoot) resultRoot.innerHTML = '<div class="empty-state panel">搜索出错，请刷新页面重试。</div>'
      }
    }

    var timer
    if (input) {
      input.addEventListener('input', function() {
        clearTimeout(timer)
        timer = setTimeout(function() { runSearch(input.value) }, 200)
      })
    }

    suggestButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        var value = button.getAttribute('data-suggest') || ''
        if (input) input.value = value
        runSearch(value)
      })
    })

    initPagefind()
  </script>
</SiteLayout>
