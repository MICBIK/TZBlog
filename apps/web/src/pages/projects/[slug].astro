---
import ArticleBody from '../../components/ArticleBody.astro'
import DetailSidebar from '../../components/DetailSidebar.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getProjects } from '../../lib/payload'

export async function getStaticPaths() {
  const projects = await getProjects()
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }))
}

const { project: currentProject } = Astro.props
---
<SiteLayout title={`${currentProject.title} · 项目档案 | TZBlog`} description={currentProject.summary}>
  <ThreeColumnLayout>
  <Fragment slot="left">
   <DetailSidebar eyebrow={currentProject.stage} title={currentProject.title} summary={currentProject.summary} chips={[currentProject.updatedAt, currentProject.orbit]} tags={currentProject.tags}>
   <div class="side-panel flow-sm panel">
        <p class="eyebrow">Quick Links</p>
      <div class="side-list rail-list-col">
       {currentProject.links.map((link) => (
     <a href={link.href} class="text-sm link-muted">{link.label} ↗</a>
        ))}
     </div>
   </div>
    </DetailSidebar>
  </Fragment>
  <Fragment slot="main">
   <ArticleBody sections={currentProject.sections} />
  </Fragment>

    <Fragment slot="right">
   <div class="side-panel flow-sm panel">
    <p class="eyebrow">Highlights</p>
    <ul class="text-sm highlights-list">
    {currentProject.highlights.map((item) => (
     <li class="link-muted">{item}</li>
    ))}
    </ul>
    </div>
   <div class="side-panel flow-sm panel">
    <p class="eyebrow">Tech Stack</p>
   <div class="tag-list-flex">
    {currentProject.stack.map((item) => (
    <span class="tag">{item}</span>
   ))}
   </div>
    </div>
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
