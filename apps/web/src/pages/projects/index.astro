---
import ContentCard from '../../components/ContentCard.astro'
import CollectionHeader from '../../components/CollectionHeader.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { collectionStats, projects } from '../../data/content'
---
<SiteLayout title="项目 | TZBlog" description="项目档案页，采用网格优先的扫描式布局。">
  <ThreeColumnLayout>
    <Fragment slot="left">
      <CollectionHeader eyebrow="Projects" title="项目档案" description="项目状态、架构说明与里程碑" count={collectionStats.projects} unit="个项目轨道" />
    </Fragment>

    <Fragment slot="main">
      <div class="content-stack">
        {projects.map((project) => (
          <ContentCard href={`/projects/${project.slug}`} eyebrow={project.stage} title={project.title} summary={project.summary} meta={`${project.updatedAt} · ${project.orbit}`} tags={project.tags} />
        ))}
      </div>
    </Fragment>

    <Fragment slot="right">
      <div class="side-panel flow-sm panel">
        <p class="eyebrow">Project Filter</p>
        <div class="tag-list" style="display: flex; flex-direction: column; gap: 0.5rem">
          <span class="tag" style="background: rgba(255,255,255,0.05)">In Progress</span>
          <span class="tag">Planned</span>
          <span class="tag">Concept</span>
        </div>
      </div>
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
