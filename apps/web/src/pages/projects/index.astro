---
import ContentCard from '../../components/ContentCard.astro'
import CollectionHeader from '../../components/CollectionHeader.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getProjects } from '../../lib/payload'

const projects = await getProjects()
const projectTagCounts = new Map<string, number>()
projects.flatMap((p) => p.tags || []).forEach((t) => projectTagCounts.set(t, (projectTagCounts.get(t) || 0) + 1))
const projectTopTags = [...projectTagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 5).map(([tag]) => tag)
---
<SiteLayout title="项目 | TZBlog" description="项目档案页，采用网格优先的扫描式布局。">
  <ThreeColumnLayout>
    <Fragment slot="left">
      <CollectionHeader eyebrow="Projects" title="项目档案" description="项目状态、架构说明与里程碑" count={projects.length} unit="个项目轨道" />
    </Fragment>

    <Fragment slot="main">
      <div class="content-stack">
        {projects.length > 0 ? (
          projects.map((project) => (
            <ContentCard href={`/projects/${project.slug}`} eyebrow={project.stage} title={project.title} summary={project.summary} meta={`${project.updatedAt} · ${project.orbit}`} tags={project.tags} />
          ))
        ) : (
          <div class="empty-state panel">当前还没有已发布项目，或者 Payload API 暂时不可用。</div>
        )}
      </div>
    </Fragment>

    <Fragment slot="right">
      {projectTopTags.length > 0 && (
        <div class="side-panel flow-sm panel">
          <p class="eyebrow">Tags</p>
          <div class="tag-list">
            {projectTopTags.map((tag) => (
              <a href={`/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>
            ))}
          </div>
          <a href="/tags" class="muted text-sm">查看全部标签 →</a>
        </div>
      )}
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
