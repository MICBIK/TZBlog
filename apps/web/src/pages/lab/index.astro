---
import SiteLayout from '../../layouts/SiteLayout.astro'
import { labExperiments } from '../../data/content'
---

<SiteLayout title="实验室 | TZBlog" description="概念验证、小工具与渐进增强试验区。">
  <section class="page-intro panel">
    <div class="page-intro-grid">
      <div class="flow-md">
        <p class="eyebrow">Lab</p>
        <h1>实验室舱段</h1>
        <p class="section-copy">这里放试验性内容，但它们不会反过来干扰文章、项目和文档的主节奏。</p>
      </div>
      <aside class="side-panel flow-sm">
        <p class="eyebrow">Rule</p>
        <p class="muted">能做实验，但别拿主站当试验田。</p>
      </aside>
    </div>
  </section>

  <section class="page-section lab-grid">
    {labExperiments.map((item) => (
      <article class="lab-card panel flow-sm">
        <p class="eyebrow">{item.tag}</p>
        <h3>{item.title}</h3>
        <p class="muted">{item.summary}</p>
        <div class="hero-status">
          <span class="status-chip">{item.status}</span>
        </div>
        <a href={item.href} class="button button-ghost">打开实验入口</a>
      </article>
    ))}
  </section>
</SiteLayout>
