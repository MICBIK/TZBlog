---
import ArticleBody from '../../components/ArticleBody.astro'
import DetailSidebar from '../../components/DetailSidebar.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { notes } from '../../data/content'

export function getStaticPaths() {
 return notes.map((note) => ({ params: { slug: note.slug }, props: { note } }))
}

const { note } = Astro.props
---

<SiteLayout title={`${note.title} | TZBlog`} description={note.summary}>
  <ThreeColumnLayout>
    <Fragment slot="left">
    <DetailSidebar eyebrow={note.mood} title={note.title} summary={note.summary} chips={[note.publishedAt]} tags={note.tags} />
   </Fragment>
   <Fragment slot="main">
   <ArticleBody sections={note.sections} />
    </Fragment>

    <Fragment slot="right">
      <div class="side-panel flow-sm panel">
    <p class="eyebrow">Entry Type</p>
     <p class="muted text-sm">这类页面用于记录开发过程中值得保留但不需要拉成完整长文的判断。</p>
     </div>
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
