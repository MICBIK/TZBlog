---
import ArticleBody from '../../components/ArticleBody.astro'
import DetailSidebar from '../../components/DetailSidebar.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getNotes } from '../../lib/payload'

export async function getStaticPaths() {
  const notes = await getNotes()
  return notes.map((note) => ({ params: { slug: note.slug }, props: { note } }))
}

const { note: currentNote } = Astro.props
---

<SiteLayout title={`${currentNote.title} | TZBlog`} description={currentNote.summary}>
  <ThreeColumnLayout>
    <Fragment slot="left">
    <DetailSidebar eyebrow={currentNote.mood} title={currentNote.title} summary={currentNote.summary} chips={[currentNote.publishedAt]} tags={currentNote.tags} />
   </Fragment>
   <Fragment slot="main">
   <div data-pagefind-body>
     <ArticleBody sections={currentNote.sections} />
   </div>
    </Fragment>

    <Fragment slot="right">
      <div class="side-panel flow-sm panel">
    <p class="eyebrow">Entry Type</p>
     <p class="muted text-sm">这类页面用于记录开发过程中值得保留但不需要拉成完整长文的判断。</p>
     </div>
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
