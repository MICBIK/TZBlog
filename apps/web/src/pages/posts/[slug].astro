---
import ArticleBody from '../../components/ArticleBody.astro'
import DetailSidebar from '../../components/DetailSidebar.astro'
import TableOfContents from '../../components/TableOfContents.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getPosts } from '../../lib/payload'

export async function getStaticPaths() {
  const posts = await getPosts()

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previous: posts[index + 1] ?? null,
      next: posts[index - 1] ?? null,
    },
  }))
}

const { post: currentPost, previous, next } = Astro.props
---

<SiteLayout title={`${currentPost.title} | TZBlog`} description={currentPost.summary}>
  <ThreeColumnLayout>
   <Fragment slot="left">
    <DetailSidebar eyebrow={currentPost.category} title={currentPost.title} summary={currentPost.summary} chips={[currentPost.publishedAt, currentPost.readTime]} tags={currentPost.tags} />
   </Fragment>
    <Fragment slot="main">
      <ArticleBody sections={currentPost.sections} />

      <section class="page-section article-footer-nav" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem;">
    <div class="panel flow-sm" style="padding: 1.5rem">
       <p class="eyebrow">上一篇</p>
      {previous ? <a href={`/posts/${previous.slug}`} style="font-weight: 600">{previous.title}</a> : <p class="muted">没有了</p>}
     </div>
        <div class="panel flow-sm" style="padding: 1.5rem; text-align: right">
     <p class="eyebrow">下一篇</p>
      {next ? <a href={`/posts/${next.slug}`} style="font-weight: 600">{next.title}</a> : <p class="muted">没有了</p>}
   </div>
    </section>
    </Fragment>

    <Fragment slot="right">
   <TableOfContents sections={currentPost.sections} />
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
