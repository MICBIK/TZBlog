---
import ContentCard from '../../components/ContentCard.astro'
import CollectionHeader from '../../components/CollectionHeader.astro'
import HighlightCard from '../../components/HighlightCard.astro'
import ThreeColumnLayout from '../../components/ThreeColumnLayout.astro'
import SiteLayout from '../../layouts/SiteLayout.astro'
import { getPosts } from '../../lib/payload'

const posts = await getPosts()
const featuredPost = posts.find((post) => post.featured) ?? posts[0]
const tagCounts = new Map<string, number>()
posts.flatMap((p) => p.tags || []).forEach((t) => tagCounts.set(t, (tagCounts.get(t) || 0) + 1))
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 5).map(([tag]) => tag)
---
<SiteLayout title="文章 | TZBlog" description="TZBlog 的文章主列表页，默认采用阅读优先的列表布局。">
  <ThreeColumnLayout>
    <Fragment slot="left">
      <CollectionHeader eyebrow="Orbit Index" title="文章航线" description="技术拆解、工程复盘、设计判断和长期写作统一放在这里。" count={posts.length} unit="篇文章" />
      <div class="side-panel flow-sm panel">
        <p class="eyebrow">Reading Radar</p>
        <div class="side-list">
          <div>
            <strong>推荐先看</strong>
            <p class="muted">观测站布局系统、内容契约、动效边界。</p>
          </div>
        </div>
      </div>
    </Fragment>

    <Fragment slot="main">
      <div class="content-stack">
        {posts.length > 0 ? (
          posts.map((post) => (
            <ContentCard href={`/posts/${post.slug}`} eyebrow={post.category} title={post.title} summary={post.summary} meta={`${post.publishedAt} · ${post.readTime}`} tags={post.tags} />
          ))
        ) : (
          <div class="empty-state panel">当前还没有已发布文章，或者 Payload API 暂时不可用。</div>
        )}
      </div>
    </Fragment>

    <Fragment slot="right">
      {topTags.length > 0 && (
        <div class="side-panel flow-sm panel">
          <p class="eyebrow">Tags</p>
          <div class="tag-list">
            {topTags.map((tag) => (
              <a href={`/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>
            ))}
          </div>
          <a href="/tags" class="muted text-sm">查看全部标签 →</a>
        </div>
      )}
      {featuredPost ? (
        <HighlightCard eyebrow="Featured Signal" title={featuredPost.title} summary={featuredPost.summary} href={`/posts/${featuredPost.slug}`} />
      ) : (
        <div class="empty-state panel">暂无精选文章可显示。</div>
      )}
    </Fragment>
  </ThreeColumnLayout>
</SiteLayout>
