---
import BaseLayout from './BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import { navItems, siteMeta } from '../data/content'

interface Props {
  title: string
  description?: string
}

const { title, description = siteMeta.description } = Astro.props
const currentPath = Astro.url.pathname
---

<BaseLayout title={title} description={description}>
  <div class="app-shell">
    <!-- High-Fidelity Celestial Backdrop (Three.js Engine) -->
    <div class="planet-background-container" aria-hidden="true">
      <canvas id="celestial-canvas">您的浏览器不支持 canvas 渲染</canvas>
    </div>

    <script>
      import * as THREE from 'three';

      const canvas = document.getElementById('celestial-canvas');
      if (canvas instanceof HTMLCanvasElement) {
        try {
        const controller = new AbortController();
        const { signal } = controller;
        let width = window.innerWidth;
        let height = window.innerHeight;

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
        camera.position.z = 100;

        const renderer = new THREE.WebGLRenderer({
          canvas, antialias: true, alpha: true, powerPreference: "high-performance"
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(width, height);

        const planetGroup = new THREE.Group();
        scene.add(planetGroup);

        const generateTexture = () => {
          const canvas = document.createElement('canvas');
          canvas.width = 1024; canvas.height = 512;
          const ctx = canvas.getContext('2d');
          if (!ctx) return null;
          for(let i=0; i<512; i++) {
            const base = 125 + Math.sin(i * 0.03) * 12 + Math.sin(i * 0.06) * 6;
            const noise = Math.random() * 8 - 4;
            const r = base + noise + 15;
            const g = base * 0.92 + noise + 8;
            const b = base * 0.82 + noise;
            ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
            ctx.fillRect(0, i, 1024, 1);
          }
          return new THREE.CanvasTexture(canvas);
        };

        const generateCraterBumpMap = () => {
          const bc = document.createElement('canvas');
          bc.width = 1024; bc.height = 512;
          const bx = bc.getContext('2d');
          if (!bx) return null;
          bx.fillStyle = '#888888';
          bx.fillRect(0, 0, 1024, 512);
          for (let i = 0; i < 180; i++) {
            const cx = Math.random() * 1024;
            const cy = Math.random() * 512;
            const r = 8 + Math.random() * 52;
            const g = bx.createRadialGradient(cx, cy, 0, cx, cy, r);
            g.addColorStop(0,    'rgba(50,50,50,0.9)');
            g.addColorStop(0.55, 'rgba(185,185,185,0.7)');
            g.addColorStop(0.85, 'rgba(128,128,128,0.3)');
            g.addColorStop(1,    'rgba(128,128,128,0)');
            bx.fillStyle = g;
            bx.beginPath(); bx.arc(cx, cy, r, 0, Math.PI * 2); bx.fill();
          }
          const id = bx.getImageData(0, 0, 1024, 512);
          for (let p = 0; p < id.data.length; p += 4) {
            const n = (Math.random() - 0.5) * 24;
            id.data[p] = Math.min(255, Math.max(0, id.data[p] + n));
            id.data[p+1] = id.data[p]; id.data[p+2] = id.data[p];
          }
          bx.putImageData(id, 0, 0);
          return new THREE.CanvasTexture(bc);
        };

        const geometry = new THREE.SphereGeometry(20, 128, 128);
        const material = new THREE.MeshStandardMaterial({
          map: generateTexture(), roughness: 0.55, metalness: 0.05,
          bumpMap: generateCraterBumpMap(), bumpScale: 3.5
        });
        const planet = new THREE.Mesh(geometry, material);
        planetGroup.add(planet);

        const glowGeo = new THREE.SphereGeometry(20.5, 64, 64);
        const glowMat = new THREE.ShaderMaterial({
          uniforms: {
            glowColor: { value: new THREE.Color(0x887755) },
            viewVector: { value: camera.position }
          },
          vertexShader: `
            varying vec3 vNormal;
            void main() { vNormal = normalize( normalMatrix * normal ); gl_Position = projectionMatrix * modelViewMatrix * vec4( position, 1.0 ); }
          `,
          fragmentShader: `
            uniform vec3 glowColor; varying vec3 vNormal;
            void main() {
              float intensity = pow( 0.65 - dot( vNormal, vec3(0.0, 0.0, 1.0) ), 5.0 );
              gl_FragColor = vec4( glowColor, intensity * 0.5 );
            }
          `,
          side: THREE.BackSide, blending: THREE.AdditiveBlending, transparent: true
        });
        planetGroup.add(new THREE.Mesh(glowGeo, glowMat));

        // Thick particle ring — three layers, no RingGeometry
        const buildRingParticles = () => {
          const layers = [
            { count: 8000,  rMin: 24, rMax: 30, ySpreadMin: 0.6,  ySpreadMax: 0.6  },
            { count: 52000, rMin: 30, rMax: 44, ySpreadMin: 1.2,  ySpreadMax: 2.2  },
            { count: 10000, rMin: 44, rMax: 52, ySpreadMin: 0.8,  ySpreadMax: 1.6  },
          ];
          const totalCount = layers.reduce((s, l) => s + l.count, 0);
          const pPos = new Float32Array(totalCount * 3);
          const pCol = new Float32Array(totalCount * 3);
          const pSz  = new Float32Array(totalCount);
          let idx = 0;
          for (const layer of layers) {
            for (let i = 0; i < layer.count; i++) {
              const r  = layer.rMin + Math.random() * (layer.rMax - layer.rMin);
              const t  = (r - layer.rMin) / (layer.rMax - layer.rMin);
              const ys = layer.ySpreadMin + t * (layer.ySpreadMax - layer.ySpreadMin);
              const th = Math.random() * Math.PI * 2;
              pPos[idx*3]   = Math.cos(th) * r;
              pPos[idx*3+1] = (Math.random() - 0.5) * 2 * ys;
              pPos[idx*3+2] = Math.sin(th) * r;
              const s = 0.45 + Math.random() * 0.35;
              pCol[idx*3]   = s * (0.95 + Math.random() * 0.1);
              pCol[idx*3+1] = s * (0.82 + Math.random() * 0.1);
              pCol[idx*3+2] = s * (0.60 + Math.random() * 0.1);
              pSz[idx] = 0.04 + Math.random() * 0.14;
              idx++;
            }
          }
          const pGeo = new THREE.BufferGeometry();
          pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
          pGeo.setAttribute('color',    new THREE.BufferAttribute(pCol, 3));
          planetGroup.add(new THREE.Points(pGeo, new THREE.PointsMaterial({
            size: 0.10, vertexColors: true, transparent: true,
            opacity: 0.78, blending: THREE.AdditiveBlending, sizeAttenuation: true
          })));
        };
        buildRingParticles();

        const starCount = 5000;
        const sPos = new Float32Array(starCount * 3);
        const sOp = new Float32Array(starCount);
        for(let i=0; i<starCount; i++) {
          sPos[i*3] = (Math.random()-0.5)*1500; sPos[i*3+1] = (Math.random()-0.5)*1000; sPos[i*3+2] = (Math.random()-1)*500;
          sOp[i] = Math.random();
        }
        const sGeo = new THREE.BufferGeometry();
        sGeo.setAttribute('position', new THREE.BufferAttribute(sPos, 3));
        sGeo.setAttribute('opacity', new THREE.BufferAttribute(sOp, 1));
        const stars = new THREE.Points(sGeo, new THREE.PointsMaterial({ size: 0.8, color: 0xffffff, transparent: true, blending: THREE.AdditiveBlending }));
        scene.add(stars);

        const asteroids: Array<{ mesh: THREE.Mesh, speed: number, dist: number, angle: number }> = [];
        const createAst = (r: number, speed: number, dist: number, ang: number) => {
          const ast = new THREE.Mesh(new THREE.SphereGeometry(r, 8, 8), new THREE.MeshStandardMaterial({ color: 0x444444, roughness: 1 }));
          scene.add(ast); return { mesh: ast, speed, dist, angle: ang };
        };
        asteroids.push(createAst(1.2, 0.005, 70, 0), createAst(0.8, 0.008, 90, Math.PI), createAst(0.5, 0.012, 110, Math.PI/2));

        const meteorMesh = new THREE.Mesh(new THREE.PlaneGeometry(20, 0.2), new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0, blending: THREE.AdditiveBlending, side: THREE.DoubleSide }));
        scene.add(meteorMesh);
        let mActive = false, mProg = 0;
        const resetM = () => { meteorMesh.position.set((Math.random()-0.5)*400, (Math.random()-0.5)*200, -100); meteorMesh.rotation.z = Math.random()*Math.PI; mProg = 0; mActive = true; };

        const sun = new THREE.DirectionalLight(0xfff4d6, 2.0); sun.position.set(100, 30, 60); scene.add(sun);
        const fill = new THREE.DirectionalLight(0x405060, 0.2); fill.position.set(-50, 0, -50); scene.add(fill);
        scene.add(new THREE.AmbientLight(0x101010));

        // Offset persists across all pages for consistency
        planetGroup.position.set(width > 1200 ? 35 : 15, 0, 0);

        // Quaternion-based drag — no gimbal lock
        let isDragging = false, lastX = 0, lastY = 0, mX = 0, mY = 0;
        const dragQuat = new THREE.Quaternion();
        const _yAxis   = new THREE.Vector3(0, 1, 0);
        const _xAxis   = new THREE.Vector3(1, 0, 0);
        let autoRotY   = 0;

        window.addEventListener('mousedown', (e) => { isDragging = true; lastX = e.clientX; lastY = e.clientY; }, { signal });
        window.addEventListener('mouseup',   () => isDragging = false, { signal });
        window.addEventListener('mousemove', (e) => {
          mX = (e.clientX / window.innerWidth  - 0.5) * 2;
          mY = (e.clientY / window.innerHeight - 0.5) * 2;
          if (isDragging) {
            const dx = (e.clientX - lastX) * 0.012;
            const dy = (e.clientY - lastY) * 0.012;
            lastX = e.clientX; lastY = e.clientY;
            const qY = new THREE.Quaternion().setFromAxisAngle(_yAxis, dx);
            const qX = new THREE.Quaternion().setFromAxisAngle(_xAxis, dy);
            dragQuat.premultiply(qY).multiply(qX);
          }
        }, { signal });

        const animate = () => {
          const time = Date.now() * 0.001;
          autoRotY = time * 0.04;
          // Compose: dragQuat * autoRotation
          const autoQ = new THREE.Quaternion().setFromAxisAngle(_yAxis, autoRotY);
          planetGroup.quaternion.copy(dragQuat).multiply(autoQ);
          // Float up/down independent of rotation
          planetGroup.position.y = Math.sin(time * 0.6) * 1.5;
          camera.position.x += (mX * 12 - camera.position.x) * 0.015;
          camera.position.y += (mY * -8 - camera.position.y) * 0.015;
          camera.lookAt(planetGroup.position);

          stars.rotation.z += 0.00005;
          const sAttr = sGeo.attributes.opacity;
          if (sAttr) { for(let i=0; i<starCount; i++) { sAttr.array[i] = 0.4+Math.sin(time*2+i)*0.4; } sAttr.needsUpdate = true; }
          asteroids.forEach(a => { a.angle += a.speed; a.mesh.position.x = planetGroup.position.x + Math.cos(a.angle)*a.dist; a.mesh.position.z = Math.sin(a.angle)*a.dist; a.mesh.position.y = Math.sin(a.angle*0.5)*15; a.mesh.rotation.y += 0.01; });
          if (!mActive && Math.random() < 0.003) resetM();
          if (mActive) { mProg += 0.04; meteorMesh.position.x += 15; meteorMesh.position.y -= 7; if (meteorMesh.material instanceof THREE.MeshBasicMaterial) meteorMesh.material.opacity = Math.sin(mProg*Math.PI); if (mProg >= 1) mActive = false; }
          renderer.render(scene, camera);
          requestAnimationFrame(animate);
        };
        animate();

        window.addEventListener('resize', () => {
          renderer.setSize(window.innerWidth, window.innerHeight);
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
          planetGroup.position.x = window.innerWidth > 1200 ? 35 : 15;
        }, { signal });

        window.addEventListener('beforeunload', () => controller.abort(), { once: true });
        } catch (error) {
          console.warn('WebGL initialization failed, falling back to plain background:', error);
          canvas.style.display = 'none';
        }
      }
    </script>
    <SiteHeader currentPath={currentPath} navItems={navItems} />
    <main id="main-content" class="page-shell shell">
      <slot />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
