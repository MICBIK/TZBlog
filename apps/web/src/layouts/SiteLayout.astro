---
import BaseLayout from './BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import { navItems, siteMeta } from '../data/content'

interface Props {
  title: string
  description?: string
}

const { title, description = siteMeta.description } = Astro.props
const currentPath = Astro.url.pathname
---

<BaseLayout title={title} description={description}>
  <div class="app-shell">
    <div class="space-backdrop" aria-hidden="true">
      <div class="space-grid"></div>
      <div class="space-glow space-glow-a"></div>
      <div class="space-glow space-glow-b"></div>
    </div>
    <SiteHeader currentPath={currentPath} navItems={navItems} />
    <main id="main-content" class="page-shell shell">
      <slot />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
