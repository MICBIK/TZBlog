---
import BaseLayout from './BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import { navItems, siteMeta } from '../data/content'

interface Props {
  title: string
  description?: string
}

const { title, description = siteMeta.description } = Astro.props
const currentPath = Astro.url.pathname
---

<BaseLayout title={title} description={description}>
  <div class="app-shell">
    <!-- High-Fidelity Celestial Backdrop (Three.js Engine) -->
    <div class="planet-background-container" aria-hidden="true">
      <canvas id="celestial-canvas"></canvas>
    </div>

    <script>
      import * as THREE from 'three';

      const canvas = document.getElementById('celestial-canvas');
      if (canvas instanceof HTMLCanvasElement) {
        let width = window.innerWidth;
        let height = window.innerHeight;

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
        camera.position.z = 100;

        const renderer = new THREE.WebGLRenderer({
          canvas, antialias: true, alpha: true, powerPreference: "high-performance"
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(width, height);

        const planetGroup = new THREE.Group();
        scene.add(planetGroup);

        const generateTexture = () => {
          const canvas = document.createElement('canvas');
          canvas.width = 1024; canvas.height = 512;
          const ctx = canvas.getContext('2d');
          if (!ctx) return null;
          for(let i=0; i<512; i++) {
            const base = 125 + Math.sin(i * 0.03) * 12 + Math.sin(i * 0.06) * 6;
            const noise = Math.random() * 8 - 4;
            const r = base + noise + 15;
            const g = base * 0.92 + noise + 8;
            const b = base * 0.82 + noise;
            ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
            ctx.fillRect(0, i, 1024, 1);
          }
          return new THREE.CanvasTexture(canvas);
        };

        const geometry = new THREE.SphereGeometry(20, 128, 128);
        const material = new THREE.MeshStandardMaterial({
          map: generateTexture(), roughness: 0.4, metalness: 0.05
        });
        const planet = new THREE.Mesh(geometry, material);
        planetGroup.add(planet);

        const glowGeo = new THREE.SphereGeometry(20.5, 64, 64);
        const glowMat = new THREE.ShaderMaterial({
          uniforms: {
            glowColor: { value: new THREE.Color(0x887755) },
            viewVector: { value: camera.position }
          },
          vertexShader: `
            varying vec3 vNormal;
            void main() { vNormal = normalize( normalMatrix * normal ); gl_Position = projectionMatrix * modelViewMatrix * vec4( position, 1.0 ); }
          `,
          fragmentShader: `
            uniform vec3 glowColor; varying vec3 vNormal;
            void main() {
              float intensity = pow( 0.65 - dot( vNormal, vec3(0.0, 0.0, 1.0) ), 5.0 );
              gl_FragColor = vec4( glowColor, intensity * 0.5 );
            }
          `,
          side: THREE.BackSide, blending: THREE.AdditiveBlending, transparent: true
        });
        planetGroup.add(new THREE.Mesh(glowGeo, glowMat));

        const generateRingTexture = () => {
          const canvas = document.createElement('canvas');
          canvas.width = 128; canvas.height = 1024;
          const ctx = canvas.getContext('2d');
          if (!ctx) return null;
          const drawBand = (start, end, color, opacity) => {
            const grad = ctx.createLinearGradient(0, start, 0, end);
            grad.addColorStop(0, 'rgba(0,0,0,0)');
            grad.addColorStop(0.2, color.replace('1)', opacity + ')'));
            grad.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = grad; ctx.fillRect(0, start, 128, end - start);
          };
          drawBand(300, 450, 'rgba(160,150,130,1)', 0.15);
          drawBand(460, 750, 'rgba(215,200,170,1)', 0.45);
          drawBand(780, 950, 'rgba(195,185,165,1)', 0.4);
          const tex = new THREE.CanvasTexture(canvas);
          tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
          return tex;
        };

        const ringGeo = new THREE.RingGeometry(24, 52, 128);
        const pos = ringGeo.attributes.position;
        const uvs = ringGeo.attributes.uv;
        for (let i = 0; i < pos.count; i++) {
          const d = Math.sqrt(pos.getX(i)**2 + pos.getY(i)**2);
          uvs.setXY(i, 0.5, (d - 24) / 28);
        }
        planetGroup.add(new THREE.Mesh(ringGeo, new THREE.MeshStandardMaterial({
          map: generateRingTexture(), side: THREE.DoubleSide, transparent: true, opacity: 0.8, roughness: 1
        })));

        const particleCount = 20000;
        const pPos = new Float32Array(particleCount * 3);
        const pCol = new Float32Array(particleCount * 3);
        for(let i=0; i<particleCount; i++) {
          const r = 24 + Math.random() * 21; const th = Math.random() * Math.PI * 2;
          pPos[i*3] = Math.cos(th) * r; pPos[i*3+1] = (Math.random()-0.5)*0.5; pPos[i*3+2] = Math.sin(th)*r;
          const s = 0.4 + Math.random() * 0.4;
          pCol[i*3] = s; pCol[i*3+1] = s*0.9; pCol[i*3+2] = s*0.8;
        }
        const pGeo = new THREE.BufferGeometry();
        pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
        pGeo.setAttribute('color', new THREE.BufferAttribute(pCol, 3));
        planetGroup.add(new THREE.Points(pGeo, new THREE.PointsMaterial({
          size: 0.08, vertexColors: true, transparent: true, opacity: 0.6, blending: THREE.AdditiveBlending
        })));

        const starCount = 5000;
        const sPos = new Float32Array(starCount * 3);
        const sOp = new Float32Array(starCount);
        for(let i=0; i<starCount; i++) {
          sPos[i*3] = (Math.random()-0.5)*1500; sPos[i*3+1] = (Math.random()-0.5)*1000; sPos[i*3+2] = (Math.random()-1)*500;
          sOp[i] = Math.random();
        }
        const sGeo = new THREE.BufferGeometry();
        sGeo.setAttribute('position', new THREE.BufferAttribute(sPos, 3));
        sGeo.setAttribute('opacity', new THREE.BufferAttribute(sOp, 1));
        const stars = new THREE.Points(sGeo, new THREE.PointsMaterial({ size: 0.8, color: 0xffffff, transparent: true, blending: THREE.AdditiveBlending }));
        scene.add(stars);

        const asteroids = [];
        const createAst = (r, speed, dist, ang) => {
          const ast = new THREE.Mesh(new THREE.SphereGeometry(r, 8, 8), new THREE.MeshStandardMaterial({ color: 0x444444, roughness: 1 }));
          scene.add(ast); return { mesh: ast, speed, dist, angle: ang };
        };
        asteroids.push(createAst(1.2, 0.005, 70, 0), createAst(0.8, 0.008, 90, Math.PI), createAst(0.5, 0.012, 110, Math.PI/2));

        const meteorMesh = new THREE.Mesh(new THREE.PlaneGeometry(20, 0.2), new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0, blending: THREE.AdditiveBlending, side: THREE.DoubleSide }));
        scene.add(meteorMesh);
        let mActive = false, mProg = 0;
        const resetM = () => { meteorMesh.position.set((Math.random()-0.5)*400, (Math.random()-0.5)*200, -100); meteorMesh.rotation.z = Math.random()*Math.PI; mProg = 0; mActive = true; };

        const sun = new THREE.DirectionalLight(0xfff4d6, 2.0); sun.position.set(100, 30, 60); scene.add(sun);
        const fill = new THREE.DirectionalLight(0x405060, 0.2); fill.position.set(-50, 0, -50); scene.add(fill);
        scene.add(new THREE.AmbientLight(0x101010));

        // Offset persists across all pages for consistency
        planetGroup.position.set(width > 1200 ? 35 : 15, 0, 0);

        let isDragging = false, lastX = 0, lastY = 0, tRotX = 0, tRotY = 0, cRotX = 0, cRotY = 0, mX = 0, mY = 0;
        window.addEventListener('mousedown', (e) => { isDragging = true; lastX = e.clientX; lastY = e.clientY; });
        window.addEventListener('mouseup', () => isDragging = false);
        window.addEventListener('mousemove', (e) => {
          mX = (e.clientX / window.innerWidth - 0.5) * 2; mY = (e.clientY / window.innerHeight - 0.5) * 2;
          if (isDragging) { tRotY += (e.clientX-lastX)*0.01; tRotX += (e.clientY-lastY)*0.01; lastX=e.clientX; lastY=e.clientY; }
        });

        const animate = () => {
          const time = Date.now() * 0.001;
          if (!isDragging) { tRotY += (mX * 0.8 - tRotY) * 0.05; tRotX += (mY * 0.4 - tRotX) * 0.05; }
          cRotX += (tRotX - cRotX) * 0.08; cRotY += (tRotY - cRotY) * 0.08;
          planetGroup.rotation.x = cRotX; planetGroup.rotation.y = cRotY + time * 0.04;
          planetGroup.position.y = Math.sin(time * 0.6) * 1.5;
          camera.position.x += (mX * 12 - camera.position.x) * 0.015;
          camera.position.y += (mY * -8 - camera.position.y) * 0.015;
          camera.lookAt(planetGroup.position);

          stars.rotation.z += 0.00005;
          const sAttr = sGeo.attributes.opacity;
          if (sAttr) { for(let i=0; i<starCount; i++) { sAttr.array[i] = 0.4+Math.sin(time*2+i)*0.4; } sAttr.needsUpdate = true; }
          asteroids.forEach(a => { a.angle += a.speed; a.mesh.position.x = planetGroup.position.x + Math.cos(a.angle)*a.dist; a.mesh.position.z = Math.sin(a.angle)*a.dist; a.mesh.position.y = Math.sin(a.angle*0.5)*15; a.mesh.rotation.y += 0.01; });
          if (!mActive && Math.random() < 0.003) resetM();
          if (mActive) { mProg += 0.04; meteorMesh.position.x += 15; meteorMesh.position.y -= 7; if (meteorMesh.material instanceof THREE.MeshBasicMaterial) meteorMesh.material.opacity = Math.sin(mProg*Math.PI); if (mProg >= 1) mActive = false; }
          renderer.render(scene, camera);
          requestAnimationFrame(animate);
        };
        animate();

        window.addEventListener('resize', () => {
          renderer.setSize(window.innerWidth, window.innerHeight);
          camera.aspect = window.innerWidth / window.innerHeight;
          camera.updateProjectionMatrix();
          planetGroup.position.x = window.innerWidth > 1200 ? 35 : 15;
        });
      }
    </script>
    <SiteHeader currentPath={currentPath} navItems={navItems} />
    <main id="main-content" class="page-shell shell">
      <slot />
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
