---
import { footerNavItems } from '../data/content'
import { getSiteSettings } from '../lib/payload'

const settings = await getSiteSettings()
const { siteMeta, socialLinks } = settings
---

<footer class="site-footer shell">
  <div class="panel dock-grid">
    <div class="flow-sm">
      <p class="eyebrow">Footer Dock</p>
      <h2>{siteMeta.title}</h2>
      <p class="muted">{siteMeta.description}</p>
    </div>

    <div class="flow-sm">
      <p class="eyebrow">Navigation Relay</p>
      <div class="footer-links">
        {footerNavItems.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </div>

    <div class="flow-sm">
      <p class="eyebrow">External Signals</p>
      <div class="footer-links">
        {socialLinks.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
