---
interface Props {
  name: string
  description: string
  stars: number
  language?: string | null
  url: string
}

const { name, description, stars = 0, language, url } = Astro.props
---

<article class="project-card panel flow-sm">
  <div class="project-card-header">
    <h3>
      <a href={url} target="_blank" rel="noopener noreferrer" aria-label={`${name} (在新窗口中打开)`}>
        {name}
      </a>
    </h3>
    <span class="project-star-badge">{stars.toLocaleString()} ★</span>
  </div>
  <p class="muted text-sm">{description}</p>
  {language && (
    <div class="project-card-meta">
      <span class="project-language-tag">{language}</span>
    </div>
  )}
</article>
