---
interface Props {
  eyebrow: string
  title: string
  description: string
  count?: number
  unit?: string
}
const { eyebrow, title, description, count, unit } = Astro.props
---

<div class="side-panel flow-sm panel">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="muted text-sm">{description}</p>
  {count !== undefined && unit && (
   <span class="status-chip">{count} {unit}</span>
  )}
</div>

<slot />
