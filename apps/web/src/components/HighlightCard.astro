---
interface Props {
  eyebrow: string
  title: string
  summary: string
  href: string
  buttonText?: string
}

const { eyebrow, title, summary, href, buttonText = '阅读' } = Astro.props
---

<div class="side-panel flow-sm panel">
  <p class="eyebrow">{eyebrow}</p>
  <strong>{title}</strong>
  <p class="muted text-sm">{summary}</p>
  <a href={href} class="button button-ghost mt-half">{buttonText}</a>
</div>
