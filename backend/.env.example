# Server Configuration
SERVER_PORT=8080
SERVER_MODE=development
SERVER_BASE_URL=http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=tzblog
# ⚠️ SECURITY: Production requires ≥32 characters, no common words (postgres, password, admin, etc.)
DB_PASSWORD=tzblog
DB_NAME=tzblog_dev
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
# ⚠️ SECURITY: Production requires ≥16 characters
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
# ⚠️ SECURITY: Production requires ≥32 characters, no default values
JWT_SECRET=dev_secret_key_at_least_32_characters_long_12345
JWT_EXPIRY=168h

# Storage Configuration (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
