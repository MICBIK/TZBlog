# ============================================
# TZBlog 生产环境配置模板
# ============================================
# ⚠️  警告: 这是生产环境配置模板
# ⚠️  所有密钥必须使用强随机值，不能使用示例值
# ⚠️  请复制此文件为 .env.production 并修改所有 CHANGE_ME 值
# ============================================

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080
SERVER_MODE=production
# ⚠️ CRITICAL: 生产环境必须使用 HTTPS
SERVER_BASE_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ============================================
# Database Configuration
# ============================================
DB_HOST=your-postgres-host.example.com
DB_PORT=5432
DB_USER=tzblog_prod
# ⚠️ CRITICAL: 生产环境数据库密码要求
# - 长度: ≥32 字符
# - 复杂度: 必须包含大小写字母、数字、特殊字符
# - 禁止: 不能包含 "password", "admin", "postgres", "tzblog" 等常见词
# - 熵: 必须达到高熵标准 (≥3.5)
#
# 生成强密码命令:
# openssl rand -base64 32
# 或
# pwgen -s 40 1
DB_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
DB_NAME=tzblog_production
# ⚠️ CRITICAL: 生产环境必须启用 SSL
DB_SSLMODE=require

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=your-redis-host.example.com
REDIS_PORT=6379
# ⚠️ CRITICAL: 生产环境必须设置 Redis 密码
# - 长度: ≥16 字符
# - 生成命令: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_24
REDIS_DB=0

# ============================================
# JWT Configuration
# ============================================
# ⚠️ CRITICAL: JWT 密钥要求
# - 长度: ≥32 字符
# - 复杂度: 必须高熵随机字符串
# - 禁止: 不能使用默认值或常见词
# - 轮换: 建议每 90 天轮换一次
#
# 生成强密钥命令:
# openssl rand -base64 48 | tr -d '\n' && echo
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48
JWT_EXPIRY=168h

# ============================================
# Storage Configuration (Cloudflare R2)
# ============================================
# ⚠️ CRITICAL: 生产环境必须配置完整的 R2 凭证
# 从 Cloudflare Dashboard -> R2 -> Manage R2 API Tokens 获取
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=tzblog-production
R2_PUBLIC_URL=https://cdn.yourdomain.com

# ============================================
# Cache Configuration (可选，使用默认值)
# ============================================
# L1_TTL=300
# L1_MAX_TTL=600
# SESSION_TTL=1800
# ARTICLE_TTL=3600

# ============================================
# Timeout Configuration (可选，使用默认值)
# ============================================
# TIMEOUT_DATABASE=10
# TIMEOUT_REDIS=5
# TIMEOUT_UPLOAD=30
# TIMEOUT_API=30

# ============================================
# 安全检查清单 - 部署前必须确认
# ============================================
# [ ] 所有 CHANGE_ME 已替换为真实值
# [ ] 所有密钥使用 openssl 或 pwgen 生成（不是手动输入）
# [ ] DB_PASSWORD 长度 ≥32 字符
# [ ] REDIS_PASSWORD 长度 ≥16 字符
# [ ] JWT_SECRET 长度 ≥32 字符
# [ ] SERVER_BASE_URL 使用 https://
# [ ] DB_SSLMODE=require
# [ ] R2 配置完整（从 Cloudflare Dashboard 获取）
# [ ] 密钥已安全存储（不提交到版本控制）
# [ ] 已备份所有密钥到密钥管理系统
# [ ] 服务器 .env.production 文件权限: chmod 600
# [ ] .env.production 已添加到 .gitignore

# ============================================
# 密钥轮换计划
# ============================================
# JWT_SECRET: 每 90 天轮换
# DB_PASSWORD: 每 180 天轮换
# REDIS_PASSWORD: 每 180 天轮换
# R2 密钥: 每 365 天轮换
#
# 详见: docs/security/key-rotation.md

# ============================================
# 快速启动指南
# ============================================
# 1. 复制此文件:
#    cp .env.production.example .env.production
#
# 2. 生成所有密钥:
#    echo "DB_PASSWORD=$(openssl rand -base64 32)" >> .env.production.local
#    echo "REDIS_PASSWORD=$(openssl rand -base64 24)" >> .env.production.local
#    echo "JWT_SECRET=$(openssl rand -base64 48)" >> .env.production.local
#
# 3. 手动编辑 .env.production，替换:
#    - SERVER_BASE_URL (你的域名)
#    - DB_HOST, DB_USER, DB_NAME (你的数据库信息)
#    - REDIS_HOST (你的 Redis 地址)
#    - R2 配置 (从 Cloudflare Dashboard 获取)
#
# 4. 合并 .env.production.local 到 .env.production
#
# 5. 设置文件权限:
#    chmod 600 .env.production
#
# 6. 测试配置:
#    go run cmd/server/main.go
#
# 详细文档: docs/security/production-config.md
