POSTGRES_DB=tzblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
CMS_PORT=3000
WEB_PORT=4321

# GitHub API (可选，公开 repo 无需 token；私有 repo 或提高限流需要)
GITHUB_TOKEN=

# Umami Analytics
UMAMI_BASE_URL=
UMAMI_API_KEY=
UMAMI_WEBSITE_ID=
# Umami tracking script URL (injected into <head>, e.g. https://analytics.example.com/script.js)
UMAMI_TRACKING_URL=

# Vercel Deploy Hook (CMS 内容变更时自动触发 Web 重新构建)
VERCEL_DEPLOY_HOOK_URL=

# S3 / R2 Media Storage (留空则使用本地文件系统)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_ENDPOINT=
