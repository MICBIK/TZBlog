POSTGRES_DB=tzblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
CMS_PORT=3000
WEB_PORT=4321

# GitHub API (可选，公开 repo 无需 token；私有 repo 或提高限流需要)
GITHUB_TOKEN=

# Umami Analytics
# Self-hosted: UMAMI_BASE_URL=http://localhost:3001
# Cloud: UMAMI_BASE_URL=https://cloud.umami.is
UMAMI_BASE_URL=
UMAMI_API_KEY=
UMAMI_WEBSITE_ID=
# Umami tracking script URL (injected into <head>)
# Self-hosted: http://localhost:3001/script.js
# Cloud: https://cloud.umami.is/script.js
UMAMI_TRACKING_URL=
# Umami App Secret (仅 self-hosted 需要，用于 docker-compose.umami.yml)
UMAMI_APP_SECRET=

# Vercel Deploy Hook (CMS 内容变更时自动触发 Web 重新构建)
VERCEL_DEPLOY_HOOK_URL=

# S3 / R2 Media Storage (留空则使用本地文件系统)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_ENDPOINT=
