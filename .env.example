# ============================================================
# TZBlog 环境变量样例
# 复制为 .env 后填写真实值；.env 不入仓库（见 .gitignore）
# ============================================================

# --- 数据库 -------------------------------------------------
# Prisma 主连接：postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tzblog
# 仅本地 prisma migrate dev 时用（影子库）；生产可不填
SHADOW_DATABASE_URL=

# --- 认证（Auth.js v5）-------------------------------------
# openssl rand -base64 32
AUTH_SECRET=
# 站点 URL，开发常为 http://localhost:3000
AUTH_URL=http://localhost:3000

# --- 管理员初始账号（仅首次 seed 用）------------------------
# seed 完成后请立刻在后台修改密码
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- 媒体存储 -----------------------------------------------
# STORAGE_DRIVER: local（默认，写到 public/uploads/）或 s3（连 MinIO/S3）
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=public/uploads
LOCAL_PUBLIC_URL_PREFIX=/uploads
# 以下 S3_* 仅 STORAGE_DRIVER=s3 时使用
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=tzblog-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/tzblog-media

# --- GitHub（首页贡献图 / 项目卡）---------------------------
# 公开 repo 可不填；提高 GitHub API 限流需要 personal access token
GITHUB_TOKEN=
GITHUB_USERNAME=

# --- 站点元信息（用于 RSS / sitemap / OG）-------------------
SITE_URL=http://localhost:3000
SITE_NAME=TZBlog

# --- Node ---------------------------------------------------
NODE_ENV=development
PORT=3000

# --- Docker（仅 docker-compose 读取，应用进程不依赖）-------
# 生产 Caddy 站点域名 / 媒体域名
SITE_DOMAIN=localhost
CDN_DOMAIN=cdn.localhost
# Postgres 容器初始化用
POSTGRES_DB=tzblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# MinIO 容器初始化用
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Magic link 邮件（Resend）--------------------------------
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=TZBlog <onboarding@resend.dev>
# 频控哈希盐，建议每月轮换
RATE_LIMIT_DAILY_SALT=
