#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# 获取当前分支名
BRANCH_NAME=$(git branch --show-current)

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  🔍 Pre-commit Hook"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "Current branch: $BRANCH_NAME"
echo ""

# 检查分支名称
if [[ "$BRANCH_NAME" =~ ^feature/backend/.+ ]]; then
  BRANCH_TYPE="backend"
  echo "✅ Backend feature branch"
elif [[ "$BRANCH_NAME" =~ ^feature/frontend/.+ ]]; then
  BRANCH_TYPE="frontend"
  echo "✅ Frontend feature branch"
elif [[ "$BRANCH_NAME" =~ ^(hotfix|release|main|develop)(/.*)?$ ]]; then
  BRANCH_TYPE="special"
  echo "✅ Special branch (no scope check)"
else
  echo "❌ Invalid branch name!"
  echo ""
  echo "Branch naming rules:"
  echo "  - feature/backend/<name> - for backend changes"
  echo "  - feature/frontend/<name> - for frontend changes"
  echo "  - hotfix/<name> - for urgent fixes"
  echo "  - release/<version> - for releases"
  echo ""
  exit 1
fi

# 获取暂存的文件
STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
  echo "⚠️  No files staged for commit"
  exit 0
fi

echo "Staged files:"
echo "$STAGED_FILES"
echo ""

# 检查文件范围（仅对 feature 分支）
if [ "$BRANCH_TYPE" = "backend" ]; then
  INVALID_FILES=$(echo "$STAGED_FILES" | grep -v "^backend/" | grep -v "^\.github/" | grep -v "^docker-compose\.yml$" | grep -v "^README\.md$" | grep -v "^docs/" | grep -v "^\.husky/" || true)

  if [ -n "$INVALID_FILES" ]; then
    echo "❌ Backend branch should only modify backend/ directory!"
    echo ""
    echo "Invalid files:"
    echo "$INVALID_FILES"
    echo ""
    echo "Tip: Use 'git reset HEAD <file>' to unstage files"
    exit 1
  fi

  echo "✅ All files are in backend/ scope"

elif [ "$BRANCH_TYPE" = "frontend" ]; then
  INVALID_FILES=$(echo "$STAGED_FILES" | grep -v "^frontend/" | grep -v "^\.github/" | grep -v "^docker-compose\.yml$" | grep -v "^README\.md$" | grep -v "^docs/" | grep -v "^\.husky/" || true)

  if [ -n "$INVALID_FILES" ]; then
    echo "❌ Frontend branch should only modify frontend/ directory!"
    echo ""
    echo "Invalid files:"
    echo "$INVALID_FILES"
    echo ""
    echo "Tip: Use 'git reset HEAD <file>' to unstage files"
    exit 1
  fi

  echo "✅ All files are in frontend/ scope"
fi

echo ""
echo "✅ Pre-commit checks passed!"
echo ""
