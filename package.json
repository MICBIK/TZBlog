    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "hast-util-to-string": "^3.0.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.469.0",
    "minio": "^8.0.7",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.25",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
